---
import Layout from "../layouts/Layout.astro";
import "../styles/portfolio-theme.css";
---

<Layout title="404 - Path Not Found">
  <div class="error-container">
    <div class="terminal-card">
      <div class="terminal-header">
        <div class="dots">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <div class="terminal-title">system_error.log</div>
      </div>
      
      <div class="terminal-body">
        <div class="error-line">
          <span class="prompt">></span> <span class="cmd">status_check --path=current</span>
        </div>
        <div class="output error">
          [CRITICAL ERROR] 404: RESOURCE_NOT_FOUND
        </div>
        <div class="output">
          Traceback (most recent call last):<br/>
          &nbsp;&nbsp;File "navigator.sys", line 404, in locate_resource<br/>
          &nbsp;&nbsp;Error: Path does not exist in the known universe.
        </div>
        
        <div class="error-line mt-4">
          <span class="prompt">></span> <span class="cmd">repair_route --target=@anthonycursewl</span>
        </div>
        <div class="output success">
          Initiating automated recovery...
        </div>
        <div class="output highlight">
          Redirecting to safe zone in <span id="countdown">3</span>s
        </div>
      </div>
    </div>
    
    <a href="/b/@anthonycursewl" class="back-link">
      <span>take me back manually</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <script is:inline>
    let seconds = 3;
    const countdownEl = document.getElementById('countdown');
    
    const interval = setInterval(() => {
      seconds--;
      if (countdownEl) countdownEl.textContent = seconds;
      
      if (seconds <= 0) {
        clearInterval(interval);
        window.location.href = "/b/@anthonycursewl";
      }
    }, 1000);
  </script>

  <style is:global>
    body {
      background-color: #0a0a0c !important;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .error-container {
      width: 90%;
      max-width: 500px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .terminal-card {
      width: 100%;
      background: #0d0d0f;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 30px 60px rgba(0,0,0,0.8);
      animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
    }

    .terminal-header {
      background: #16161b;
      padding: 10px 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .dots {
      position: absolute;
      left: 16px;
      display: flex;
      gap: 6px;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .red { background: #ff5f56; }
    .yellow { background: #ffbd2e; }
    .green { background: #27c93f; }

    .terminal-title {
      font-size: 0.75rem;
      color: #94a3b8;
      font-family: var(--font-code);
      opacity: 0.7;
    }

    .terminal-body {
      padding: 1.5rem;
      font-family: var(--font-code);
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .error-line {
      display: flex;
      gap: 10px;
      margin-bottom: 0.5rem;
    }

    .prompt { color: #ffffff; opacity: 0.5; }
    .cmd { color: #ffffff; }
    
    .output {
      color: #94a3b8;
      margin-bottom: 0.5rem;
    }

    .output.error {
      color: #f87171;
      font-weight: 700;
    }

    .output.success {
      color: #4ade80;
    }

    .output.highlight {
      color: #ffffff;
      margin-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 1rem;
    }

    .back-link {
      color: #ffffff;
      text-decoration: none;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0.6;
      transition: all 0.3s ease;
      font-family: var(--font-code);
      background: rgba(255, 255, 255, 0.05);
      padding: 8px 16px;
      border-radius: 99px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .back-link:hover {
      opacity: 1;
      background: rgba(255, 255, 255, 0.1);
      transform: translateY(-2px);
    }

    .mt-4 { margin-top: 1.5rem; }

    @keyframes shake {
      10%, 90% { transform: translate3d(-1px, 0, 0); }
      20%, 80% { transform: translate3d(2px, 0, 0); }
      30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
      40%, 60% { transform: translate3d(4px, 0, 0); }
    }
  </style>
</Layout>
