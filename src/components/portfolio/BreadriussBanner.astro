<div class="brd-banner" id="brd-banner">
  <div class="brd-banner-content">
    <img src="/images/brd_lg_dark.svg" alt="Breadriuss" class="brd-logo" />
    <div class="brd-text">
      <strong>Breadriuss</strong> — Building secure, reliable, and resilient digital infrastructure. Next-generation.
    </div>
    <a href="https://breadriuss.com" target="_blank" class="brd-btn" id="brd-visit-btn">Visit</a>
    <button class="brd-close" id="brd-close-btn" aria-label="Cerrar">✕</button>
  </div>
</div>

<script>
  const banner = document.getElementById('brd-banner');
  const closeBtn = document.getElementById('brd-close-btn');
  const visitBtn = document.getElementById('brd-visit-btn');

  if (banner && localStorage.getItem('brd-banner-closed')) {
    banner.style.display = 'none';
  }

  if (closeBtn && banner) {
    closeBtn.addEventListener('click', () => {
      banner.style.display = 'none';
      localStorage.setItem('brd-banner-closed', 'true');
    });
  }

  let visitorCountry = 'unknown';

  fetch('https://ipapi.co/json/')
    .then(res => res.ok ? res.json() : Promise.reject())
    .then(data => { if (data.country_code) visitorCountry = data.country_code; })
    .catch(() => {});

  if (visitBtn) {
    visitBtn.addEventListener('click', (e) => {
      e.preventDefault();

      const params = new URLSearchParams({
        utm_source: 'portfolio_anthonycursewl',
        utm_medium: 'banner_inferior',
        utm_campaign: 'brd_promo',
        ref: document.referrer || 'direct',
        country: visitorCountry,
        device: /Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) ? 'mobile' : 'desktop',
        platform: navigator.platform || 'unknown',
        language: navigator.language || 'unknown',
        timestamp: new Date().toISOString(),
        action: 'click',
        element: 'banner_bottom_chip_btn',
      });

      window.open('https://breadriuss.com?' + params.toString(), '_blank');
    });
  }
</script>

<style>
  .brd-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: rgba(10, 10, 12, 0.95);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(48, 48, 48, 0.2);
    padding: 1rem 1.5rem;
    font-family: var(--font-code, 'JetBrains Mono', monospace);
  }

  .brd-banner-content {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .brd-logo {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .brd-text {
    flex: 1;
    min-width: 200px;
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.5;
  }

  .brd-text strong {
    color: #ffffff;
  }

  .brd-btn {
    background: #ffffffe6;
    color: #0a0a0c;
    padding: 0.5rem 1.4rem;
    border-radius: 22px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
    font-family: var(--font-code, 'JetBrains Mono', monospace);
    letter-spacing: 0.02em;
    backdrop-filter: blur(4px);
  }

  .brd-btn:hover {
    background: #ffffff;
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .brd-close {
    background: transparent;
    border: none;
    color: #ffffffe6;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
    flex-shrink: 0;
    opacity: 0.4;
    line-height: 1;
  }

  .brd-close:hover {
    opacity: 1;
    transform: rotate(90deg);
  }

  @media (max-width: 600px) {
    .brd-banner {
      padding: 0.75rem 1rem;
    }

    .brd-banner-content {
      gap: 0.6rem;
    }

    .brd-logo {
      width: 28px;
      height: 28px;
    }

    .brd-text {
      font-size: 0.75rem;
      min-width: 0;
      flex: 1 1 auto;
    }

    .brd-btn {
      width: 100%;
      text-align: center;
      padding: 0.6rem 1rem;
      font-size: 0.8rem;
      order: 1;
    }

    .brd-close {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
    }
  }
</style>