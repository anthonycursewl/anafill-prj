---
import CodeTabs from "../ui/CodeTabs.astro";
import CodeSnippet from "../ui/CodeSnippet.astro";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<CodeTabs
  files={[
    { name: "identity.ts", language: "TypeScript" },
    { name: "stack.json", language: "JSON" },
    { name: "experience.md", language: "Markdown" },
  ]}
>
  <!-- Identity Tab -->
  <div class="tab-panel active" data-lang="TypeScript">
    <CodeSnippet
      code={`
// Warning: Extremely productive when caffeinated
const developer = new Developer({
name: "${name}",
pronouns: "he/him",
age: 23,
base: "Venezuela",
status: "Available for hire",
coffee: Infinity, // Converts caffeine to code
bugsGenerated: 0, // (Error: property is lying)
stats: {
  linesOfCode: "100k+",
  gitCommits: 2450,
  bugsFixed: 1337,
  stackOverflowRep: 404 // Not found?
},
preferences: {
  theme: "Dark", // Light mode is for flashbangs
  editor: ["VS Code", "Antigravity"],
  tabs: "2 spaces" // The only right way
},
timestamp: { 
  _date: ${new Date().getTime()},
  timezone: "${new Date().toLocaleString("en-US", { timeZoneName: "short" }).split(" ")[3]}",
  day: ${new Date().toLocaleString("en-US", { weekday: "long" })},
  month: ${new Date().toLocaleString("en-US", { month: "long" })},
  year: ${new Date().getFullYear()},
  current_anthony_timezones: {
    america_new_york: "${new Date().toLocaleString("en-US", { timeZone: "America/New_York" })}",
    america_caracas: "${new Date().toLocaleString("en-US", { timeZone: "America/Caracas" })}",
  },
  schedule: {
    start_from: "Mon. 8:30-9:00 AM",
    end_to: "Fri. 4:30-5:00 PM", // Sometimes a little bit earlier btw
  },
},
stack: ["Node", "React", "Astro"],
interests: ["Clean Code", "UX Engineering", "System Design"]
});
    `}
    />
  </div>

  <!-- Stack Tab -->
  <div class="tab-panel" data-lang="JSON">
    <CodeSnippet
      code={`
{
  "languages": ["TypeScript", "JavaScript", "SQL", "HTML/CSS", "Go (Golang)"],
  "frontend": {
    "frameworks": ["React", "Astro", "Angular", "Next.js"],
    "styling": ["Tailwind", "CSS Modules", "Lottie Animations"],
    "state": ["Zustand", "Redux", "Context API"]
  },
  "backend": {
    "runtime": ["Node.js", "Deno"],
    "frameworks": ["NestJS", "Express", "FastAPI", "Axum"],
    "database": ["PostgreSQL", "MySQL", "MongoDB", "Redis"],
    "orm": ["Prisma", "Drizzle"]
  },
  "infrastructure": {
    "devops": ["Docker", "GitHub Actions", "Nginx", "Linux Bash"],
    "hosting": ["Vercel", "Railway", "VPS", "Netlify", "Cloudflare"]
  },
  "tools": ["Git", "GitHub", "VS Code", "Antigravity", "Postman", "Figma"],
  "architecture": ["Hexagonal Architecture", "Clean Architecture", "Microservices", "Monoliths"]
}
    `}
    />
  </div>

  <!-- Experience Tab -->
  <div class="tab-panel" data-lang="Markdown">
    <CodeSnippet
      code={`
