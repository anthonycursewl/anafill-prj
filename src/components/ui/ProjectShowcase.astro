---
import CodeSnippet from "./CodeSnippet.astro";
import Carousel from "./Carousel.astro";

interface Props {
  title: string;
  description: string;
  fileName: string;
  language: string;
  images: string[];
  code?: string;
}

const { title, description, fileName, language, images, code } = Astro.props;
---

<div class="project-showcase">
  <div class="project-header" data-project-header>
    <div class="project-skeleton">
      <div class="skeleton-item title"></div>
      <div class="skeleton-item desc"></div>
      <div class="skeleton-item desc short"></div>
    </div>

    <div class="project-real-content" style="display: none;">
      <h3 class="project-title dynamic-typewriter">{title}</h3>
      <p class="project-description dynamic-typewriter">{description}</p>
      <div class="thought-wrapper" style="display: none;">
        <span class="thought-label">Thought</span>
        <span class="thought-value"
          >{(Math.random() * (3 - 1) + 1).toFixed(1)}s</span
        >
      </div>
    </div>
  </div>

  <div class="project-editor-block">
    <div class="editor-header">
      <div class="editor-dots"><span></span><span></span><span></span></div>
      <span class="editor-filename">{fileName}</span>
      <span class="editor-lang">{language}</span>
    </div>
    <div class="editor-content">
      {code ? <CodeSnippet code={code} /> : <slot />}
    </div>
  </div>

  <Carousel images={images} title={title} />
</div>

<style>
  .project-showcase {
    margin-bottom: 6rem;
    animation: fadeIn 0.8s ease-out forwards;
  }

  .project-header {
    margin-bottom: 2rem;
    min-height: 120px; /* Prevent layout shift */
  }

  /* Skeleton Shimmer */
  .project-skeleton {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .skeleton-item {
    background: linear-gradient(90deg, #1a1a1f 25%, #25252b 50%, #1a1a1f 75%);
    background-size: 200% 100%;
    animation: shimmer 2s infinite linear;
    border-radius: 4px;
  }

  .skeleton-item.title {
    height: 28px;
    width: 40%;
  }

  .skeleton-item.desc {
    height: 16px;
    width: 90%;
  }

  .skeleton-item.desc.short {
    width: 60%;
  }

  @keyframes shimmer {
    from {
      background-position: -200% 0;
    }
    to {
      background-position: 200% 0;
    }
  }

  .project-title {
    font-size: 1.75rem;
    color: #ffffff;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .project-description {
    color: #94a3b8;
    font-size: 1rem;
    line-height: 1.6;
    white-space: pre-wrap;
    margin-bottom: 1rem;
  }

  .thought-wrapper {
    background: #16161b;
    padding: 0.1rem 0.6rem;
    width: fit-content;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1.2rem;
    font-family: var(--font-code);
    font-size: 0.8rem;
    color: #64748b;
    display: flex;
    gap: 0.3rem;
    margin-top: 1rem;
    opacity: 0.8;
  }

  .thought-label {
    font-weight: 600;
    color: #475569;
  }

  .project-editor-block {
    background: #0d0d0f;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .editor-header {
    background: #16161b;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .editor-dots {
    display: flex;
    gap: 6px;
  }

  .editor-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }

  .editor-filename {
    color: #94a3b8;
    font-size: 0.75rem;
    font-family: "Fira Code", monospace;
    flex-grow: 1;
  }

  .editor-lang {
    color: #64748b;
    font-size: 0.7rem;
    font-family: "Fira Code", monospace;
    text-transform: uppercase;
  }

  .editor-content {
    padding: 1.5rem;
    font-family: var(--font-code);
    font-size: 0.85rem;
    line-height: 1.7;
    overflow-x: auto;
  }

  .project-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .gallery-item {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
    background: #16161b;
    aspect-ratio: 16/10;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    border-color: rgba(167, 139, 250, 0.3);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .gallery-item:hover img {
    opacity: 1;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 600px) {
    .project-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
