---
---
<div class="tech-background">
  <!-- Hexagonal Honeycomb Grid -->
  <div class="hexagon-grid">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hexagons" width="50" height="43.4" patternUnits="userSpaceOnUse" patternTransform="scale(2)">
          <path d="M25 0 L50 14.4 L50 29 L25 43.4 L0 29 L0 14.4 Z" fill="none" stroke="rgba(167, 139, 250, 0.05)" stroke-width="1" />
        </pattern>
        
        <filter id="glow-tech" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
      </defs>
      <rect width="100%" height="100%" fill="url(#hexagons)" />
      
      <!-- Random Pulsing Hexagons (SVG elements controlled by CSS) -->
      <g class="pulsing-hexagons">
        <path d="M125 43.4 L150 57.8 L150 72.4 L125 86.8 L100 72.4 L100 57.8 Z" class="p-hex h-1" />
        <path d="M325 130.2 L350 144.6 L350 159.2 L325 173.6 L300 159.2 L300 144.6 Z" class="p-hex h-2" />
        <path d="M525 217 L550 231.4 L550 246 L525 260.4 L500 246 L500 231.4 Z" class="p-hex h-3" />
        <path d="M725 86.8 L750 101.2 L750 115.8 L725 130.2 L700 115.8 L700 101.2 Z" class="p-hex h-4" />
        <path d="M225 347.2 L250 361.6 L250 376.2 L225 390.6 L200 376.2 L200 361.6 Z" class="p-hex h-5" />
      </g>
    </svg>
  </div>

  <!-- Binary Matrix Rain/Floating -->
  <div class="binary-matrix">
    {Array.from({ length: 15 }).map((_, i) => (
      <div class="binary-column" style={`--delay: ${Math.random() * 5}s; --left: ${i * 7}%; --speed: ${5 + Math.random() * 5}s`}>
        {Array.from({ length: 20 }).map(() => (
          <span>{Math.round(Math.random())}</span>
        ))}
      </div>
    ))}
  </div>

  <div class="overlay-effects">
    <div class="vignette"></div>
    <div class="scanline"></div>
  </div>
</div>

<style>
  .tech-background {
    position: absolute;
    inset: 0;
    background: #020205;
    overflow: hidden;
    z-index: 0;
  }

  /* Hexagons */
  .hexagon-grid {
    position: absolute;
    inset: 0;
    opacity: 0.8;
  }

  .p-hex {
    fill: rgba(167, 139, 250, 0);
    stroke: rgba(167, 139, 250, 0.3);
    stroke-width: 1.5;
    filter: url(#glow-tech);
    transition: all 1s ease;
  }

  .h-1 { animation: hexPulse 6s infinite 0s; }
  .h-2 { animation: hexPulse 8s infinite 2s; }
  .h-3 { animation: hexPulse 7s infinite 1s; }
  .h-4 { animation: hexPulse 9s infinite 3s; }
  .h-5 { animation: hexPulse 10s infinite 4s; }

  @keyframes hexPulse {
    0%, 100% { 
      fill: rgba(167, 139, 250, 0); 
      opacity: 0.2;
    }
    50% { 
      fill: rgba(167, 139, 250, 0.15); 
      opacity: 0.8;
      stroke: rgba(167, 139, 250, 0.8);
    }
  }

  /* Binary Matrix */
  .binary-matrix {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: space-around;
    pointer-events: none;
    opacity: 0.25;
  }

  .binary-column {
    position: absolute;
    top: -100px;
    left: var(--left);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: #a78bfa;
    animation: matrixFall var(--speed) linear infinite var(--delay);
    white-space: nowrap;
  }

  .binary-column span {
    text-shadow: 0 0 5px #a78bfa;
  }

  @keyframes matrixFall {
    0% { transform: translateY(-100%); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(100vh); opacity: 0; }
  }

  /* Effects */
  .overlay-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 30%, #020205 100%);
  }

  .scanline {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(167, 139, 250, 0.02) 50%,
      transparent 100%
    );
    background-size: 100% 4px;
    animation: scan 10s linear infinite;
  }

  @keyframes scan {
    from { transform: translateY(-100%); }
    to { transform: translateY(100%); }
  }
</style>
